From 72dc215a88d9c29a807d0921e5dd1558b16912e3 Mon Sep 17 00:00:00 2001
From: "Jeremy (via Claude)" <centrinnovations@gmail.com>
Date: Wed, 15 Jul 2026 05:54:52 -0400
Subject: [PATCH] Add clay-ink: AA-passing text variant of clay

clay (#B8754A) fails WCAG AA as text against sand/parchment
(2.79:1 / 3.26:1, need 4.5:1) below ~18pt bold. Landing-page
accessibility pass in centrcanonapp-next flagged this on phase-card
eyebrows and taglines. Mirrors the existing muted/muted-ink split:
clay stays for decorative/large-accent use, clay-ink (#885535,
4.65:1 / 5.44:1) is the AA-safe choice whenever clay is doing text
duty.
---
 package.json       | 2 +-
 tailwind.config.ts | 3 ++-
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/package.json b/package.json
index c26c0e2..ca19e0f 100644
--- a/package.json
+++ b/package.json
@@ -1,6 +1,6 @@
 {
   "name": "@centrinnovations/design",
-  "version": "0.1.0",
+  "version": "0.1.1",
   "private": true,
   "description": "Shared design tokens (Tailwind preset), typography, and icon conventions for the CEnTR* System tool suite.",
   "main": "./tailwind.config.ts",
diff --git a/tailwind.config.ts b/tailwind.config.ts
index d3d80ce..320a0d5 100644
--- a/tailwind.config.ts
+++ b/tailwind.config.ts
@@ -18,7 +18,8 @@ export const canonColors = {
   navy:        '#1E325C',
   forest:      '#3B6B35',
   signal:      '#8E2A2A',
-  clay:        '#B8754A',
+  clay:        '#B8754A',   // decorative/large-accent only — fails AA as text on sand/parchment below ~18pt bold; use clay-ink for readable text
+  'clay-ink':  '#885535',   // darker clay text — AA-passing on sand/parchment (4.65:1 / 5.44:1); #B8754A stays for decorative/large accents
   gold:        '#C49A3A',
 
   // Earthtone palette (cluster coloring in visualizations)
-- 
2.34.1

